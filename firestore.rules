rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      // Any authenticated user can read and create their own doc
      allow read, create: if request.auth != null && request.auth.uid == userId;
      // Admin can list all users and update any user
      allow list: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow update: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /boards/{boardCode} {
      allow read, create: if true;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.ownerUid;

      match /submissions/{submissionId} {
        allow read: if true;
        // 마감된 보드에서는 교사(보드 소유자)만 쓰기 가능
        allow create: if get(/databases/$(database)/documents/boards/$(boardCode)).data.status != 'closed'
          || (request.auth != null && request.auth.uid == get(/databases/$(database)/documents/boards/$(boardCode)).data.ownerUid);
        allow update: if get(/databases/$(database)/documents/boards/$(boardCode)).data.status != 'closed'
          || (request.auth != null && request.auth.uid == get(/databases/$(database)/documents/boards/$(boardCode)).data.ownerUid);
        allow delete: if get(/databases/$(database)/documents/boards/$(boardCode)).data.status != 'closed'
          || (request.auth != null && request.auth.uid == get(/databases/$(database)/documents/boards/$(boardCode)).data.ownerUid);

        match /comments/{commentId} {
          allow read, create: if true;
          // 교사(보드 소유자)는 모든 댓글 수정/삭제 가능
          allow update, delete: if true;
        }
      }
    }
  }
}
