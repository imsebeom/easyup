rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if user is the board owner
    function isOwner(boardCode) {
      return request.auth != null
        && request.auth.uid == get(/databases/$(database)/documents/boards/$(boardCode)).data.ownerUid;
    }

    // Helper: check if board is writable (not closed/private)
    function isBoardOpen(boardCode) {
      return get(/databases/$(database)/documents/boards/$(boardCode)).data.status == 'active';
    }

    match /users/{userId} {
      allow read, create: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
      allow list, update: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /classes/{alias} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.ownerUid;

      match /slots/{slotId} {
        allow read: if true;
        allow write: if request.auth != null
          && request.auth.uid == get(/databases/$(database)/documents/classes/$(alias)).data.ownerUid;
      }
    }

    match /boards/{boardCode} {
      // Anyone can read boards (student join flow needs this)
      allow read: if true;
      // Authenticated users can create boards
      allow create: if request.auth != null;
      // Only owner can update/delete
      allow update: if (request.auth != null && request.auth.uid == resource.data.ownerUid)
        || (resource.data.status == 'active'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'groups']));
      allow delete: if request.auth != null && request.auth.uid == resource.data.ownerUid;

      match /submissions/{submissionId} {
        // Private boards: only owner can read
        allow read: if resource == null
          || get(/databases/$(database)/documents/boards/$(boardCode)).data.status != 'private'
          || isOwner(boardCode);

        // Create: board must be open, or owner can always create
        allow create: if isBoardOpen(boardCode) || isOwner(boardCode);
        // Update/Delete: board must be open, or owner can always modify
        allow update, delete: if isBoardOpen(boardCode) || isOwner(boardCode);

        match /comments/{commentId} {
          // Private boards: only owner can read comments
          allow read: if get(/databases/$(database)/documents/boards/$(boardCode)).data.status != 'private'
            || isOwner(boardCode);
          // Create: board must be open, or owner
          allow create: if isBoardOpen(boardCode) || isOwner(boardCode);
          // Update/Delete: board must be open, or owner
          allow update, delete: if isBoardOpen(boardCode) || isOwner(boardCode);
        }
      }

      // ліҙл“ң мұ„нҢ… л©”мӢңм§Җ (кіјм ң ліҙл“ң м „мІҙ мұ„нҢ… + көҗмӮ¬ к·“л§җ)
      // л№„кіөк°ң(private) ліҙл“ңлҠ” көҗмӮ¬л§Ң, к·ё мҷём—җлҠ” лҲ„кө¬лӮҳ read/create к°ҖлҠҘ
      // DM мҠӨл Ҳл“ң м ‘к·ј м ңн•ңмқҖ нҒҙлқјмқҙм–ёнҠё н•„н„°л§Ғм—җ мқҳмЎҙ (кё°мЎҙ deviceId мӢ лў° лӘЁлҚёкіј лҸҷмқј)
      match /messages/{messageId} {
        allow read: if get(/databases/$(database)/documents/boards/$(boardCode)).data.status != 'private'
          || isOwner(boardCode);
        // Create: active ліҙл“ңм—җм„ңлҠ” лҲ„кө¬лӮҳ, closedм—¬лҸ„ көҗмӮ¬лҠ” к°ҖлҠҘ. ліёл¬ё кёёмқҙ м ңн•ң.
        // chatPublicEnabled=falseл©ҙ н•ҷмғқмқҖ public мҠӨл Ҳл“ңм—җ ліҙлӮҙм§Җ лӘ»н•Ё (көҗмӮ¬лҠ” н•ӯмғҒ к°ҖлҠҘ).
        allow create: if (isBoardOpen(boardCode) || isOwner(boardCode))
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 1000
          && request.resource.data.thread is string
          && (
            isOwner(boardCode)
            || request.resource.data.thread != 'public'
            || get(/databases/$(database)/documents/boards/$(boardCode)).data.chatPublicEnabled != false
          );
        // Update/Delete: көҗмӮ¬(ліҙл“ң мҶҢмң мһҗ)л§Ң. н•ҷмғқмқҖ ліёмқё л©”мӢңм§ҖлқјлҸ„ м„ңлІ„ к·ңм№ҷм—җм„ң кІҖмҰқ л¶Ҳк°Җ.
        allow update, delete: if isOwner(boardCode);
      }
    }
  }
}
